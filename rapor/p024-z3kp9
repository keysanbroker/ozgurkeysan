<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">

<style>
  :root {
    --heading: #1E3A7A;
    --red: #D62828;
    --ink: #1d1d1f;
    --ink-soft: #6e6e73;
    --ink-faint: #a1a1a6;
    --line: #ececef;
    --line-soft: #f4f4f6;
    --bg: #FFFFFF;
    --bg-soft: #fafafa;
    --maxw: 1000px;
    --pad: 32px;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
  body {
    font-family: 'Roboto', sans-serif;
    color: var(--ink);
    background: var(--bg);
    line-height: 1.65;
    font-size: 15px;
    font-weight: 400;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
  h1, h2, h3, h4, .num, .mark { font-family: 'Poppins', sans-serif; color: var(--heading); font-weight: 600; letter-spacing: -0.02em; }
  .wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 var(--pad); }
  a { color: inherit; text-decoration: none; }

  /* TOP BAR */
  .topbar {
    border-bottom: 1px solid var(--line);
    padding: 18px 0;
    background: rgba(255,255,255,0.92);
    backdrop-filter: saturate(180%) blur(20px);
    position: sticky; top: 0; z-index: 50;
  }
  .topbar .wrap { display: flex; align-items: center; justify-content: space-between; gap: 16px; }
  .brand { display: inline-block; transition: opacity 0.2s ease; }
  .brand:hover { opacity: 0.7; }
  .brand .mark { font-weight: 600; font-size: 15px; line-height: 1; color: var(--red); }
  .brand .mark .nm { color: var(--ink); margin-right: 4px; font-weight: 600; }
  .brand .mark .sep { color: var(--ink-faint); margin: 0 8px; font-weight: 400; }
  .brand .sub {
    font-size: 10.5px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--ink-faint); margin-top: 5px; font-weight: 500;
  }
  .topbar .meta {
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--ink-faint); font-weight: 500;
  }

  /* KAPAK */
  .cover { padding: 96px 0 72px; border-bottom: 1px solid var(--line); }
  .cover .eyebrow {
    font-size: 11px; letter-spacing: 0.24em; text-transform: uppercase;
    color: var(--red); font-weight: 600; margin-bottom: 28px;
  }
  .cover h1 {
    font-size: clamp(40px, 5.5vw, 64px); font-weight: 600;
    line-height: 1.02; letter-spacing: -0.035em; margin-bottom: 18px;
  }
  .cover h1 .red { color: var(--red); }
  .cover .id-line {
    font-family: 'Poppins', sans-serif; font-size: 17px; font-weight: 400;
    color: var(--ink-soft); margin-bottom: 48px; letter-spacing: -0.005em;
  }

  .id-strip {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px;
    padding: 28px 0; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line);
    margin-bottom: 44px;
  }
  .id-cell .lbl {
    font-size: 10.5px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--ink-faint); font-weight: 500; margin-bottom: 8px;
  }
  .id-cell .val {
    font-family: 'Poppins', sans-serif; font-size: 15px; font-weight: 500;
    color: var(--ink); line-height: 1.3; letter-spacing: -0.005em;
  }

  /* Kişiye özel karşılama */
  .greeting { margin-bottom: 56px; max-width: 720px; }

  /* İki parsel kartı */
  .parcel-cards {
    display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
    margin-bottom: 44px;
  }
  .parcel-card {
    padding: 22px 26px;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 12px;
    border-left: 3px solid var(--red);
  }
  .parcel-card .pc-lbl {
    font-size: 10.5px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--ink-faint); font-weight: 500; margin-bottom: 8px;
  }
  .parcel-card .pc-num {
    font-family: 'Poppins', sans-serif;
    font-size: 20px; font-weight: 600;
    color: var(--red); letter-spacing: -0.02em; margin-bottom: 10px;
  }
  .parcel-card .pc-detail {
    font-size: 14px; color: var(--ink); line-height: 1.65;
  }
  .parcel-card .pc-detail strong { font-weight: 600; }
  @media (max-width: 540px) {
    .parcel-cards { grid-template-columns: 1fr; gap: 12px; }
  }
  .greeting .salute {
    font-family: 'Poppins', sans-serif; font-size: 19px; font-weight: 600;
    color: var(--heading); margin-bottom: 14px; letter-spacing: -0.015em;
  }
  .greeting p {
    font-size: 15.5px; color: var(--ink); line-height: 1.75; margin: 0 0 14px;
  }
  .greeting p.signoff {
    font-style: italic; color: var(--ink-soft); margin-bottom: 0;
  }

  .roadmap-title {
    font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--ink-faint); font-weight: 600; margin-bottom: 20px;
  }
  .roadmap-list { list-style: none; counter-reset: rm; }
  .roadmap-list li {
    counter-increment: rm; padding: 10px 0 10px 40px; position: relative;
    font-family: 'Poppins', sans-serif; font-size: 15.5px; font-weight: 500; color: var(--ink);
    line-height: 1.4; border-bottom: 1px solid var(--line-soft);
    letter-spacing: -0.005em;
  }
  .roadmap-list li:last-child { border-bottom: none; }
  .roadmap-list li::before {
    content: "0" counter(rm);
    position: absolute; left: 0; top: 11px;
    font-size: 13px; font-weight: 600; color: var(--red); letter-spacing: 0.04em;
  }

  /* BÖLÜMLER */
  section.block { padding: 88px 0; border-bottom: 1px solid var(--line); }
  section.block:last-of-type { border-bottom: none; }
  .block-head { margin-bottom: 44px; }
  .block-num {
    font-size: 11px; letter-spacing: 0.24em; text-transform: uppercase;
    color: var(--red); font-weight: 600; margin-bottom: 12px;
  }
  .block-head h2 {
    font-size: clamp(26px, 3vw, 32px); font-weight: 600;
    letter-spacing: -0.025em; line-height: 1.2;
  }
  .block-intro {
    font-size: 15.5px; color: var(--ink-soft); line-height: 1.65;
    margin-top: 14px; max-width: 720px; font-weight: 400;
  }
  .block-intro strong { color: var(--ink); font-weight: 600; }

  /* PORTFÖY PROFİLİ */
  .embed-wrap {
    margin-bottom: 14px;
    border-radius: 14px; overflow: hidden;
    background: var(--bg-soft);
  }
  .embed-wrap iframe { width: 100%; height: 680px; border: none; display: block; }
  .embed-actions {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 4px; gap: 12px; flex-wrap: wrap;
  }
  .embed-cap { font-size: 11.5px; color: var(--ink-faint); letter-spacing: 0.04em; }
  .embed-fullscreen {
    display: inline-flex; align-items: center; gap: 7px;
    font-family: 'Poppins', sans-serif; font-size: 12px; font-weight: 500;
    color: var(--ink); padding: 8px 14px;
    border: 1px solid var(--line); border-radius: 20px;
    transition: all 0.2s ease; letter-spacing: -0.005em;
  }
  .embed-fullscreen:hover { border-color: var(--red); color: var(--red); }
  .embed-fullscreen svg { width: 12px; height: 12px; }

  /* Konum görselleri */
  .loc-images {
    margin-top: 36px;
    display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
  }
  .loc-images .lim {
    border-radius: 10px; overflow: hidden;
    background: var(--bg-soft);
    border: 1px solid var(--line);
  }
  .loc-images .lim img {
    width: 100%; height: auto; display: block;
  }
  .loc-images .lim .cap {
    font-size: 11px; color: var(--ink-soft);
    padding: 10px 14px;
    letter-spacing: 0.02em;
    background: var(--bg);
  }

  .topo-note {
    margin-top: 32px; padding: 26px 30px;
    background: var(--bg-soft); border-radius: 12px;
  }
  .topo-note .ct {
    font-size: 10.5px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--ink-faint); font-weight: 600; margin-bottom: 14px;
  }
  .topo-note h4 {
    font-size: 15px; font-weight: 600; color: var(--ink);
    margin-bottom: 8px; letter-spacing: -0.01em;
  }
  .topo-note p {
    font-size: 14.5px; color: var(--ink); line-height: 1.75; margin: 0 0 12px;
  }
  .topo-note p:last-child { margin-bottom: 0; }
  .topo-note p strong { color: var(--ink); font-weight: 600; }

  .access-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px;
    margin: 18px 0 4px;
  }
  .access-cell {
    padding: 14px 16px;
    background: var(--bg); border-radius: 10px;
    border: 1px solid var(--line);
  }
  .access-cell .ac-loc {
    font-family: 'Poppins', sans-serif; font-size: 13px; font-weight: 600;
    color: var(--ink); margin-bottom: 6px; letter-spacing: -0.01em;
  }
  .access-cell .ac-val {
    font-family: 'Poppins', sans-serif; font-size: 16px; font-weight: 600;
    color: var(--red); letter-spacing: -0.02em;
  }
  .access-cell .ac-val .unit {
    font-size: 11px; color: var(--ink-soft); font-weight: 400; margin-left: 4px;
  }

  /* PAZAR ANALİZİ */
  .stats {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 0;
    margin-bottom: 48px;
    border-top: 1px solid var(--line); border-bottom: 1px solid var(--line);
  }
  .stat { padding: 22px 24px; border-right: 1px solid var(--line); }
  .stat:last-child { border-right: none; }
  .stat .lbl {
    font-size: 10.5px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--ink-faint); font-weight: 500; margin-bottom: 10px;
  }
  .stat .val {
    font-family: 'Poppins', sans-serif; font-size: 26px; font-weight: 600;
    color: var(--ink); line-height: 1; letter-spacing: -0.025em;
  }
  .stat .val .unit { font-size: 12px; font-weight: 400; color: var(--ink-soft); margin-left: 4px; letter-spacing: 0; }
  .stat .desc { font-size: 11.5px; color: var(--ink-soft); line-height: 1.5; margin-top: 8px; }
  .stat.accent .val { color: var(--red); }

  .table-head {
    display: flex; justify-content: space-between; align-items: baseline;
    padding-bottom: 12px; border-bottom: 1px solid var(--ink);
    margin-bottom: 4px; margin-top: 40px;
  }
  .table-head h3 { font-size: 16px; font-weight: 600; color: var(--ink); letter-spacing: -0.015em; }
  .table-head h3 .count {
    display: inline-block; margin-left: 10px; padding: 2px 9px;
    background: var(--ink); color: #fff; font-size: 10.5px; font-weight: 600;
    border-radius: 10px; letter-spacing: 0.02em; vertical-align: 2px;
  }
  .table-head h3 .count.active { background: var(--red); }
  .table-head .hint { font-size: 11.5px; color: var(--ink-faint); letter-spacing: 0.01em; }

  .lst-row {
    display: grid; grid-template-columns: 36px 60px 1fr 95px 125px 75px;
    align-items: center; gap: 14px;
    padding: 16px 14px;
    border-bottom: 1px solid var(--line-soft);
    transition: background 0.15s ease;
  }
  .lst-row:hover { background: var(--bg-soft); }
  .lst-row.anchor { box-shadow: inset 3px 0 0 var(--red); padding-left: 18px; }
  .lst-row.outlier { opacity: 0.4; }

  .lst-thumb {
    width: 60px; aspect-ratio: 3/4;
    border-radius: 6px; overflow: hidden;
    background: var(--bg-soft); border: 1px solid var(--line);
  }
  .lst-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .lst-id {
    font-family: 'Poppins', sans-serif; font-size: 12px; font-weight: 600;
    color: var(--red); letter-spacing: 0.04em;
  }
  .lst-row.outlier .lst-id { color: var(--ink-faint); }
  .lst-main .ttl {
    font-family: 'Poppins', sans-serif; font-size: 14px; font-weight: 500;
    color: var(--ink); margin-bottom: 4px; line-height: 1.3; letter-spacing: -0.01em;
  }
  .lst-main .nt { font-size: 12.5px; color: var(--ink-soft); line-height: 1.45; }
  .lst-main .nt strong { color: var(--ink); font-weight: 600; }
  .lst-rate {
    font-family: 'Poppins', sans-serif; font-size: 13px; font-weight: 600;
    color: var(--red); text-align: right; letter-spacing: -0.005em;
  }
  .lst-price {
    font-family: 'Poppins', sans-serif; font-size: 13.5px; font-weight: 600;
    color: var(--ink); text-align: right; letter-spacing: -0.01em;
  }
  .lst-days { font-size: 11.5px; color: var(--ink-faint); text-align: right; }
  .lst-days.long { color: var(--red); font-weight: 500; }

  /* İlan görselleri kartları */
  .ilan-cards {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px;
    margin-top: 36px;
  }
  .ic-card {
    border: 1px solid var(--line); border-radius: 12px; overflow: hidden;
    background: var(--bg);
  }
  .ic-card.anchor { border-color: var(--red); border-width: 1.5px; }
  .ic-card .ic-img {
    width: 100%; aspect-ratio: 4/5; overflow: hidden;
    background: var(--bg-soft);
    display: block;
  }
  .ic-card .ic-img img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .ic-card .ic-body { padding: 14px 16px; }
  .ic-card .ic-tag {
    display: inline-block;
    font-family: 'Poppins', sans-serif; font-size: 10px; font-weight: 600;
    color: var(--red); letter-spacing: 0.1em; margin-bottom: 6px;
  }
  .ic-card .ic-ttl {
    font-family: 'Poppins', sans-serif; font-size: 13px; font-weight: 600;
    color: var(--ink); margin-bottom: 4px; line-height: 1.3; letter-spacing: -0.01em;
  }
  .ic-card .ic-meta {
    font-size: 11.5px; color: var(--ink-soft); line-height: 1.5;
  }

  .market-summary {
    margin-top: 40px; padding: 24px 28px;
    background: var(--bg-soft); border-radius: 12px;
  }
  .market-summary p {
    font-size: 14.5px; color: var(--ink); line-height: 1.75; margin: 0 0 12px;
  }
  .market-summary p:last-child { margin-bottom: 0; }
  .market-summary p strong { font-weight: 600; color: var(--ink); }

  /* YILLIK GELİR POTANSİYELİ */
  .income-block {
    padding: 32px 36px;
    background: var(--bg-soft);
    border-radius: 14px;
    border-left: 3px solid var(--red);
  }
  .income-block .ib-title {
    font-family: 'Poppins', sans-serif;
    font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--red); font-weight: 600; margin-bottom: 14px;
  }
  .income-block .ib-h {
    font-family: 'Poppins', sans-serif;
    font-size: 18px; font-weight: 600;
    color: var(--ink); margin-bottom: 8px; letter-spacing: -0.015em;
    line-height: 1.35;
  }
  .income-block .ib-sub {
    font-size: 13.5px; color: var(--ink-soft);
    margin-bottom: 22px; line-height: 1.65;
  }
  .income-block .ib-sub strong { color: var(--ink); font-weight: 600; }

  .income-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;
    margin-bottom: 24px;
  }
  .income-cell {
    padding: 18px 20px;
    background: var(--bg); border-radius: 10px;
    text-align: center;
    border: 1px solid var(--line);
  }
  .income-cell.rec {
    border-color: var(--red); border-width: 1.5px;
  }
  .income-cell .ic-lbl {
    font-family: 'Poppins', sans-serif;
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--ink-soft); font-weight: 600; margin-bottom: 8px;
  }
  .income-cell.rec .ic-lbl { color: var(--red); }
  .income-cell .ic-val {
    font-family: 'Poppins', sans-serif;
    font-size: 22px; font-weight: 600;
    color: var(--heading); letter-spacing: -0.02em; line-height: 1; margin-bottom: 6px;
  }
  .income-cell.rec .ic-val { color: var(--red); }
  .income-cell .ic-det {
    font-size: 11.5px; color: var(--ink-soft); line-height: 1.4;
  }

  .income-roi {
    padding: 18px 22px;
    background: var(--bg); border-radius: 10px;
    border-left: 3px solid var(--heading);
  }
  .income-roi .roi-lbl {
    font-family: 'Poppins', sans-serif;
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--ink-soft); font-weight: 600; margin-bottom: 8px;
  }
  .income-roi p {
    font-size: 14px; color: var(--ink); line-height: 1.7; margin: 0;
  }
  .income-roi p strong { color: var(--red); font-weight: 700; }

  .income-note {
    font-size: 11.5px; color: var(--ink-soft);
    margin-top: 16px; font-style: italic; line-height: 1.55;
  }

  /* DEĞER ANALİZİ */
  .price-quote {
    font-family: 'Poppins', sans-serif; font-size: 18px; font-weight: 500;
    color: var(--ink); line-height: 1.5; margin: 0 0 40px;
    padding-left: 18px; border-left: 2px solid var(--red);
    letter-spacing: -0.015em; max-width: 720px;
  }
  .price-quote .muted {
    display: block; font-size: 14.5px; font-weight: 400; color: var(--ink-soft);
    margin-top: 6px; letter-spacing: -0.005em;
  }

  .price-grid { display: grid; grid-template-columns: 1fr; gap: 48px; }
  .price-grid > .sc-list, .price-grid > .pyramid {
    max-width: 620px; width: 100%; margin: 0 auto;
  }

  .pyramid {
    padding: 36px 32px; border-radius: 14px;
    background: var(--bg-soft);
    display: flex; flex-direction: column;
  }
  .pyramid .title {
    font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--ink-faint); font-weight: 600; margin-bottom: 24px; text-align: center;
  }
  .pyramid svg {
    width: 100%; height: auto; display: block;
    margin: auto 0;
  }

  .sc-list .sc-intro {
    font-family: 'Poppins', sans-serif; font-size: 14px; font-weight: 500;
    color: var(--ink-soft); margin-bottom: 16px; letter-spacing: -0.005em;
  }
  .sc {
    position: relative;
    padding: 20px 22px;
    border: 1px solid var(--line); border-radius: 12px;
    margin-bottom: 12px;
    background: var(--bg);
    transition: border-color 0.2s ease;
  }
  .sc:hover { border-color: var(--ink-faint); }
  .sc.rec { border-color: var(--red); border-width: 1.5px; }
  .sc.rec .rec-tag {
    position: absolute; top: -10px; left: 18px;
    background: var(--red); color: #fff;
    font-family: 'Poppins', sans-serif; font-size: 9.5px; font-weight: 600;
    padding: 4px 10px; border-radius: 4px; letter-spacing: 0.14em;
  }
  .sc-top {
    display: flex; justify-content: space-between; align-items: baseline;
    margin-bottom: 6px; gap: 12px;
  }
  .sc-lbl {
    font-family: 'Poppins', sans-serif; font-size: 14px; font-weight: 600;
    color: var(--ink); letter-spacing: -0.01em;
  }
  .sc-rate {
    font-family: 'Poppins', sans-serif; font-size: 11.5px; font-weight: 500;
    color: var(--ink-soft); white-space: nowrap;
  }
  .sc-price {
    font-family: 'Poppins', sans-serif; font-size: 20px; font-weight: 600;
    color: var(--red); line-height: 1; margin-bottom: 8px; letter-spacing: -0.02em;
  }
  .sc-desc { font-size: 13px; color: var(--ink-soft); line-height: 1.55; }

  /* Önerilen Satışa Çıkış Fiyatı */
  .final-price {
    margin-top: 56px;
    padding: 40px 44px;
    background: var(--bg);
    border: 2px solid var(--red);
    border-radius: 16px;
    text-align: center;
    max-width: 720px;
    margin-left: auto; margin-right: auto;
    box-shadow: 0 8px 32px rgba(214, 40, 40, 0.08);
  }
  .final-price .fp-title {
    font-family: 'Poppins', sans-serif;
    font-size: 11px; letter-spacing: 0.24em; text-transform: uppercase;
    color: var(--red); font-weight: 700; margin-bottom: 18px;
  }
  .final-price .fp-rate-top {
    font-family: 'Poppins', sans-serif;
    font-size: 13px; color: var(--ink-soft); font-weight: 500;
    margin-bottom: 24px; letter-spacing: 0.04em;
