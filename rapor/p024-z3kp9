<!-- LIGHTBOX -->
<div class="lightbox" id="lb">
  <button class="lb-close" id="lb-close" aria-label="Kapat">×</button>
  <img id="lb-img" src="" alt="">
</div>

<script>
(function() {
  var lb = document.getElementById('lb');
  var lbImg = document.getElementById('lb-img');
  var lbClose = document.getElementById('lb-close');

  function open(src) {
    lbImg.src = src;
    lb.classList.add('active');
    document.body.style.overflow = 'hidden';
  }
  function close() {
    lb.classList.remove('active');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('img.lb-clickable').forEach(function(img) {
    img.addEventListener('click', function(e) {
      e.stopPropagation();
      open(img.src);
    });
  });

  lb.addEventListener('click', function(e) {
    if (e.target === lb || e.target === lbClose) close();
  });
  lbClose.addEventListener('click', close);
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && lb.classList.contains('active')) close();
  });
})();
</script>

